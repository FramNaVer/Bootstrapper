
# development | production | test (default: development)
# ตอน deploy ขึ้น production ให้ตั้งเป็น production (ปกติตั้งใน dashboard ของ host ไม่ใช่ไฟล์นี้)
NODE_ENV="development"

JWT_SECRET=""
JWT_REFRESH_SECRET=""

# --- Database ---
# dev ปกติ = Postgres local จาก docker-compose (docker compose up -d)
# DATABASE_URL ใช้ตอน runtime, DIRECT_URL ใช้ตอน migrate (local = ค่าเดียวกัน)
DATABASE_URL="postgresql://app:app@localhost:5432/bootstrapper"
DIRECT_URL="postgresql://app:app@localhost:5432/bootstrapper"

# ถ้าต้องชี้ Neon (ตรวจสอบข้อมูล prod ฯลฯ): DATABASE_URL ใช้ pooler URL,
# DIRECT_URL ใช้ URL ตรง (ตัด -pooler ออก) — ห้ามรัน integration test ค้างไว้!

# DB แยกสำหรับ integration test (npm run test:integration) — เทสต์เขียน/ลบ
# ข้อมูลจริง ต้องไม่ปนกับ DB dev (สร้างให้อัตโนมัติโดย docker/init-test-db.sql)
TEST_DATABASE_URL="postgresql://app:app@localhost:5432/bootstrapper_test"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3000/api/v1/auth/github/callback"

# Base URL ของแอป — ใช้ประกอบลิงก์ verify/reset ใน email
APP_URL="http://localhost:3000"

# Sentry (error tracking) — ปล่อยว่างได้ในตอน dev (Sentry จะปิด)
# ตอน production เอา DSN จาก dashboard ของ Sentry มาใส่ใน env ของ host
SENTRY_DSN=""

# CORS — origin ของ frontend ที่อนุญาต (รองรับหลายค่า คั่นด้วย comma)
# dev = Vite (5173), production ใส่โดเมน Vercel เพิ่ม เช่น:
# ALLOWED_ORIGIN="http://localhost:5173,https://app.tanadon-t.com"
ALLOWED_ORIGIN="http://localhost:5173"

# URL ของ frontend (SPA) — ใช้ redirect กลับหลัง OAuth สำเร็จ
FRONTEND_URL="http://localhost:5173"

# Email (SMTP) — ถ้าไม่ตั้ง SMTP_HOST, dev จะ log เนื้อหา email ออก console แทนการส่งจริง
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Bootstrapper <no-reply@bootstrapper.local>"