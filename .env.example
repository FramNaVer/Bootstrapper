
# development | production | test (default: development)
# ตอน deploy ขึ้น production ให้ตั้งเป็น production (ปกติตั้งใน dashboard ของ host ไม่ใช่ไฟล์นี้)
NODE_ENV="development"

JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Pooler URL — ใช้ใน PrismaClient ตอน runtime
DATABASE_URL=""

# Direct URL — ใช้สำหรับ migrate (ตัด -pooler ออก)
DIRECT_URL=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3000/api/v1/auth/github/callback"

# Base URL ของแอป — ใช้ประกอบลิงก์ verify/reset ใน email
APP_URL="http://localhost:3000"

# Sentry (error tracking) — ปล่อยว่างได้ในตอน dev (Sentry จะปิด)
# ตอน production เอา DSN จาก dashboard ของ Sentry มาใส่ใน env ของ host
SENTRY_DSN=""

# Email (SMTP) — ถ้าไม่ตั้ง SMTP_HOST, dev จะ log เนื้อหา email ออก console แทนการส่งจริง
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Bootstrapper <no-reply@bootstrapper.local>"